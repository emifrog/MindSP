generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// MODELS PUBLICS (Multi-tenancy)
// ==========================================

model Tenant {
  id                String    @id @default(cuid())
  name              String
  slug              String    @unique
  subdomain         String    @unique
  customDomain      String?   @unique
  
  // Configuration
  settings          String    @default("{}")
  features          String    @default("")
  maxUsers          Int       @default(10)
  maxStorage        Int       @default(1000) // MB
  
  // Metadata
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  
  // Relations
  users             User[]
  subscriptions     Subscription[]
  
  @@map("tenants")
}

model Subscription {
  id                String    @id @default(cuid())
  tenantId          String
  plan              String
  status            String
  currentPeriodEnd  DateTime
  cancelAtPeriodEnd Boolean   @default(false)
  
  // Relations
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@map("subscriptions")
}

// ==========================================
// MODELS TENANT (Isolation par tenant)
// ==========================================

model User {
  id                String    @id @default(cuid())
  tenantId          String
  
  // Auth
  email             String    
  password          String
  emailVerified     DateTime?
  
  // Profile
  firstName         String
  lastName          String
  phone             String?
  avatar            String?
  
  // Role & Permissions
  role              String    @default("USER")
  permissions       String    @default("")
  
  // Metadata
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  
  // Relations
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  sessions          Session[]
  fmpas             FMPA[]    @relation("FMPAOrganizer")
  participations    FMPAParticipation[]
  messages          Message[]
  notifications     Notification[]
  
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Session {
  id                String    @id @default(cuid())
  userId            String
  token             String    @unique
  refreshToken      String    @unique
  expiresAt         DateTime
  ipAddress         String?
  userAgent         String?
  
  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([userId])
  @@map("sessions")
}


// ==========================================
// MODULE FMPA
// ==========================================

model FMPA {
  id                String    @id @default(cuid())
  tenantId          String
  
  // Informations générales
  title             String
  description       String?
  type              String
  status            String    @default("DRAFT")
  
  // Dates et lieu
  startDate         DateTime
  endDate           DateTime
  location          String
  address           String?
  
  // Configuration
  maxParticipants   Int?
  requiresValidation Boolean  @default(false)
  allowExternal     Boolean   @default(false)
  
  // QR Code
  qrCode            String?   @unique
  
  // Metadata
  createdBy         String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  canceledAt        DateTime?
  
  // Relations
  organizer         User      @relation("FMPAOrganizer", fields: [createdBy], references: [id])
  participants      FMPAParticipation[]
  
  @@index([tenantId])
  @@index([startDate])
  @@index([status])
  @@map("fmpas")
}

model FMPAParticipation {
  id                String    @id @default(cuid())
  fmpaId            String
  userId            String
  
  // Status
  status            String    @default("PENDING")
  validatedBy       String?
  validatedAt       DateTime?
  
  // Présence
  checkedInAt       DateTime?
  checkedOutAt      DateTime?
  signature         String?
  
  // Metadata
  registeredAt      DateTime  @default(now())
  canceledAt        DateTime?
  
  // Relations
  fmpa              FMPA      @relation(fields: [fmpaId], references: [id])
  user              User      @relation(fields: [userId], references: [id])
  
  @@unique([fmpaId, userId])
  @@map("fmpa_participations")
}


// ==========================================
// MODULE MESSAGERIE
// ==========================================

model Conversation {
  id                String    @id @default(cuid())
  tenantId          String
  type              String
  name              String?
  avatar            String?
  
  // Metadata
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastMessageAt     DateTime?
  
  // Relations
  messages          Message[]
  members           ConversationMember[]
  
  @@index([tenantId])
  @@map("conversations")
}

model ConversationMember {
  id                String    @id @default(cuid())
  conversationId    String
  userId            String
  role              String    @default("MEMBER")
  
  // Notifications
  mutedUntil        DateTime?
  lastReadAt        DateTime?
  
  // Metadata
  joinedAt          DateTime  @default(now())
  leftAt            DateTime?
  
  // Relations
  conversation      Conversation @relation(fields: [conversationId], references: [id])
  
  @@unique([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id                String    @id @default(cuid())
  conversationId    String
  senderId          String
  
  // Content
  content           String
  type              String    @default("TEXT")
  attachments       String?
  
  // Status
  editedAt          DateTime?
  deletedAt         DateTime?
  
  // Metadata
  createdAt         DateTime  @default(now())
  
  // Relations
  conversation      Conversation @relation(fields: [conversationId], references: [id])
  sender            User      @relation(fields: [senderId], references: [id])
  readBy            MessageRead[]
  
  @@index([conversationId, createdAt])
  @@map("messages")
}

model MessageRead {
  id                String    @id @default(cuid())
  messageId         String
  userId            String
  readAt            DateTime  @default(now())
  
  // Relations
  message           Message   @relation(fields: [messageId], references: [id])
  
  @@unique([messageId, userId])
  @@map("message_reads")
}


// ==========================================
// MODULE NOTIFICATIONS
// ==========================================

model Notification {
  id                String    @id @default(cuid())
  userId            String
  
  // Content
  type              String
  title             String
  message           String
  data              String?
  actionUrl         String?
  
  // Status
  readAt            DateTime?
  clickedAt         DateTime?
  
  // Metadata
  createdAt         DateTime  @default(now())
  
  // Relations
  user              User      @relation(fields: [userId], references: [id])
  
  @@index([userId, readAt])
  @@map("notifications")
}

